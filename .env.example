# Required: comma-separated list of API keys (raw values, hashed at startup)
CURSOR_WRAPPER_API_KEYS=your-secret-key-here

# Required: absolute path that all job working directories must be inside
CURSOR_WORKDIR_ROOT=/tmp/cursor-jobs

# Optional: port to listen on (default: 3000)
CURSOR_WRAPPER_PORT=3000

# Optional: absolute path to the cursor binary (default: /usr/local/bin/cursor)
# On macOS with the Cursor app:
# CURSOR_BIN=/Applications/Cursor.app/Contents/Resources/app/bin/cursor
# Cursor API key — used by cursor-agent to authenticate with Cursor's cloud
# CURSOR_API_KEY=your-cursor-api-key

CURSOR_BIN=/usr/local/bin/cursor

# Optional: path to allowlist.json (default: ./config/allowlist.json)
CURSOR_ALLOWLIST_PATH=./config/allowlist.json

# Optional: default timeout in milliseconds per request (default: 120000 = 2 min)
CURSOR_TIMEOUT_MS=120000

# Optional: max combined stdout+stderr bytes (default: 1048576 = 1 MB)
CURSOR_MAX_OUTPUT_BYTES=1048576

# Optional: max parallel cursor processes (default: 2)
CURSOR_MAX_CONCURRENCY=2
